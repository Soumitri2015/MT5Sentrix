<Window x:Class="Sentrix.UIPages.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
        mc:Ignorable="d"
           Width="420"
   Height="520" 
   WindowStartupLocation="CenterScreen"
   Title="Guardian Configuration"
   ResizeMode="NoResize"
   Background="#1E1E1E"
   Foreground="#D4D4D4">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="133"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="Max Trades Per Day" VerticalAlignment="Center" Height="16"/>
        <TextBox x:Name="MaxTradesBox" Grid.Row="0" Grid.Column="1" Padding="6" Margin="0,4,0,8"
             Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Trades Per Session" VerticalAlignment="Center" Height="16"/>
        <TextBox x:Name="MaxTradesPerSessionBox" Grid.Row="1" Grid.Column="1" Padding="6" Margin="0,4,0,8"
             Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Loss (%)" VerticalAlignment="Center" Height="16"/>
        <TextBox x:Name="MaxLossBox" Grid.Row="2" Grid.Column="1" Padding="6" Margin="0,4,0,8"
             Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Lock Message" VerticalAlignment="Center" Height="16"/>
        <TextBox x:Name="LockMessageBox" Grid.Row="3" Grid.Column="1" Padding="6" Margin="0,4,0,8"
             Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"/>

        <CheckBox x:Name="CloseTradesCheck" 
              Grid.Row="4" Grid.Column="1" 
              Content="Close trades if session is out of time" 
              Foreground="#D4D4D4" 
              VerticalAlignment="Center" Height="15"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Trading Sessions" FontWeight="SemiBold" VerticalAlignment="Top" Height="16" Grid.ColumnSpan="2" Margin="10,9,237,0"/>

        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,6">
            <TextBox x:Name="SessionNameBox" Width="90" Height="28" Padding="6" Margin="0,0,6,0"
                 Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"/>
            <ComboBox x:Name="StartTimePicker" Width="70" Height="28" Margin="0,0,6,0"/>
            <ComboBox x:Name="EndTimePicker" Width="70" Height="28"/>
        </StackPanel>

        <ListBox x:Name="SessionsList" Grid.Row="7" Grid.Column="1" 
             Background="#252526" Foreground="#FFFFFF" BorderBrush="#3C3C3C"
             SelectionChanged="SessionsList_SelectionChanged" Margin="0,36,0,36"/>

        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0" Width="200">
            <Button x:Name="AddSessionBtn" Content="Add Session" Width="100" Height="30" Margin="0,0,10,0"
                Background="#444444" Foreground="White" BorderThickness="0" Click="AddSession_Click"/>
            <Button Content="Save" Width="90" Height="30" 
                Background="#007ACC" Foreground="White" BorderThickness="0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
