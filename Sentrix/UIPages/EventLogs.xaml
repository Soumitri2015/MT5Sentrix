<Window x:Class="Sentrix.UIPages.EventLogs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
       Title="Event Logs"
Width="420"
Height="520"
Background="White"
WindowStartupLocation="CenterOwner">
    <Border Padding="10"
         Background="Black"
         BorderBrush="#CCCCCC"
         BorderThickness="1">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EventsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6"
                             Padding="6"
                             BorderBrush="#E0E0E0"
                             BorderThickness="0,0,0,1">

                            <StackPanel>
                                <!-- DATE + TIME -->
                                <TextBlock Text="{Binding DisplayDateTime}"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        FontSize="12"/>

                                <!-- EVENT MESSAGE -->
                                <TextBlock Text="{Binding Message}"
                                        Foreground="White"
                                        TextWrapping="Wrap"
                                        Margin="0,4,0,8"
                                        FontSize="13"/>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Border>
</Window>
