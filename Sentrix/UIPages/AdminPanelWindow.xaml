<Window x:Class="Sentrix.UIPages.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
        mc:Ignorable="d"
        Title="Admin Panel"
Width="1050"
Height="640"
WindowStartupLocation="CenterOwner"
Background="#0F1117"
FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBlue"    Color="#4A9EFF"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#9B6DFF"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#3DD68C"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#FF8C42"/>
        <SolidColorBrush x:Key="CardBg"        Color="#1A1D2E"/>
        <SolidColorBrush x:Key="InputBg"       Color="#252840"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#333655"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E8EAF6"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8891B4"/>
        <SolidColorBrush x:Key="DangerRed"     Color="#FF5370"/>

        <!-- TEXTBOX: explicit Foreground + CaretBrush fixes invisible text -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"               Value="#252840"/>
            <Setter Property="Foreground"               Value="#E8EAF6"/>
            <Setter Property="CaretBrush"               Value="#E8EAF6"/>
            <Setter Property="SelectionBrush"           Value="#4A9EFF"/>
            <Setter Property="BorderBrush"              Value="#333655"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                             Background="{TemplateBinding Background}"
                             BorderBrush="{TemplateBinding BorderBrush}"
                             BorderThickness="{TemplateBinding BorderThickness}"
                             CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                       Foreground="#E8EAF6"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       VerticalScrollBarVisibility="Hidden"
                                       HorizontalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A9EFF"/>
                                <Setter TargetName="border" Property="Background"  Value="#2D3154"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX for time pickers -->
        <Style x:Key="TimePickerStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="#252840"/>
            <Setter Property="Foreground"      Value="#E8EAF6"/>
            <Setter Property="BorderBrush"     Value="#333655"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press"
                              Background="Transparent"
                              BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                    Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                    BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                    BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                    CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                      ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                      Margin="10,0,28,0"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                                <TextBlock Text="&#9662;"
                                               Foreground="#8891B4"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,10,0"
                                               FontSize="10"
                                               IsHitTestVisible="False"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#4A9EFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       StaysOpen="False"
                       PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="180">
                                    <Border Background="#252840"
                                BorderBrush="#4A9EFF"
                                BorderThickness="1"
                                CornerRadius="6">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E8EAF6"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="FontSize"   Value="13"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2D3365"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8891B4"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,6,0,4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E8EAF6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6" Margin="0,1">
                            <ContentPresenter Margin="10,7"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#252840"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2D3365"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#333655"/>
                                <Setter Property="Foreground" Value="#555877"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EAF6"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="#1E2138"/>
            <Setter Property="AlternatingRowBackground" Value="#232640"/>
            <Setter Property="Foreground"               Value="#E8EAF6"/>
            <Setter Property="GridLinesVisibility"      Value="None"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#2D3154"/>
            <Setter Property="Foreground"      Value="#9B6DFF"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D3365"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252840"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#E8EAF6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: User list -->
        <Border Background="#1A1D2E" CornerRadius="12" BorderBrush="#333655" BorderThickness="1">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="4" CornerRadius="2" Background="#9B6DFF" Margin="0,0,8,0"/>
                        <TextBlock Text="USERS" Foreground="#9B6DFF" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid>
                        <TextBox x:Name="UserSearchBox"
                              Style="{StaticResource InputStyle}"
                              Height="34" Padding="30,0,8,0"
                              TextChanged="UserSearchBox_TextChanged"/> 
                        <TextBlock Text="&#128269;"
                                Foreground="#8891B4" FontSize="12"
                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                Margin="9,0,0,0" IsHitTestVisible="False"/>
                        <TextBlock x:Name="SearchPlaceholder"
                                Text="Search users..."
                                Foreground="#8891B4" FontSize="12"
                                VerticalAlignment="Center" Margin="30,0,0,0"
                                IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
                <ListBox x:Name="UsersList"
                      DisplayMemberPath="UserName"
                      Background="Transparent" BorderThickness="0"
                      Foreground="#E8EAF6"
                      SelectionChanged="UsersList_SelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </DockPanel>
        </Border>

        <!-- RIGHT: Config panel -->
        <Border Grid.Column="1" Margin="10,0,0,0"
             Background="#1A1D2E" CornerRadius="12"
             BorderBrush="#333655" BorderThickness="1">

            <!-- FIX: Grid with Height="*" row so ScrollViewer fills the remaining space -->
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="4" CornerRadius="2" Background="#4A9EFF" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SelectedUserText"
                                Foreground="#E8EAF6" FontSize="15" FontWeight="SemiBold"
                                Text="Select a user to configure"/>
                    </StackPanel>
                    <Button x:Name="SaveBtn" Grid.Column="1"
                         Content="&#128190;  Save Changes"
                         Width="150"
                         Style="{StaticResource PrimaryBtn}"
                         Background="#3DD68C"
                         IsEnabled="False"
                         Click="Save_Click"/>
                </Grid>

                <Separator Grid.Row="1" Background="#333655" Margin="0,0,0,12"/>

                <!-- Scrollable config content -->
                <ScrollViewer Grid.Row="2"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ConfigPanel" IsEnabled="False">

                        <!-- TRADING LIMITS -->
                        <Border Background="#1E2138" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="8" Height="8" Fill="#FF8C42"
                                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="TRADING LIMITS" Foreground="#FF8C42"
                                            FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MAX TRADES / DAY" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="MaxTradesDayBox"
                                              Style="{StaticResource InputStyle}"
                                              TextChanged="Config_TextChanged"/>
                                        <TextBlock x:Name="MaxTradesDayError"
                                                Foreground="#FF5370" FontSize="10"
                                                Visibility="Collapsed" Text="Must be a whole number"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="MAX TRADES / SESSION" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="MaxTradesSessionBox"
                                              Style="{StaticResource InputStyle}"
                                              TextChanged="Config_TextChanged"/>
                                        <TextBlock x:Name="MaxTradesSessionError"
                                                Foreground="#FF5370" FontSize="10"
                                                Visibility="Collapsed" Text="Must be a whole number"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="LOSS %" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="LossPercentBox"
                                              Style="{StaticResource InputStyle}"
                                              TextChanged="Config_TextChanged"/>
                                        <TextBlock x:Name="LossPercentError"
                                                Foreground="#FF5370" FontSize="10"
                                                Visibility="Collapsed" Text="Must be a decimal number"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LOCK SETTINGS -->
                        <Border Background="#1E2138" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="8" Height="8" Fill="#4A9EFF"
                                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="LOCK SETTINGS" Foreground="#4A9EFF"
                                            FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="LOCK MESSAGE" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LockMessageBox"
                                      Style="{StaticResource InputStyle}"
                                      TextChanged="Config_TextChanged"/>
                                <CheckBox x:Name="CloseOutsideSessionCheck"
                                       Content="Close Trades Outside Session"
                                       Margin="0,12,0,0"
                                       Checked="Config_CheckChanged"
                                       Unchecked="Config_CheckChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TRADING SESSIONS -->
                        <Border Background="#1E2138" CornerRadius="8" Padding="14,12" Margin="0,0,0,4">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#3DD68C"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="TRADING SESSIONS" Foreground="#3DD68C"
                                                FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="+"
                                         Style="{StaticResource IconBtn}"
                                         Background="#3DD68C"
                                         ToolTip="Add new session"
                                         Click="AddSession_Click"/>
                                </Grid>

                                <DataGrid x:Name="SessionsGrid"
                                       MinHeight="80" MaxHeight="220"
                                       SelectionChanged="SessionsGrid_SelectionChanged">
                                    <DataGrid.Columns>

                                        <!-- Session Name -->
                                        <DataGridTemplateColumn Header="Session Name" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SessionName}"
                       Foreground="#E8EAF6"
                       VerticalAlignment="Center" Padding="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputStyle}" Height="30"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Start" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StartTime}"
                       Foreground="#3DD68C"
                       VerticalAlignment="Center" Padding="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding TimeSlotsList, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                      Style="{StaticResource TimePickerStyle}"
                      IsDropDownOpen="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="End" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding EndTime}"
                       Foreground="#FF8C42"
                       VerticalAlignment="Center" Padding="8,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding TimeSlotsList, RelativeSource={RelativeSource AncestorType=Window}}"
                      SelectedItem="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}"
                      Style="{StaticResource TimePickerStyle}"
                      IsDropDownOpen="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <!-- Delete -->
                                        <DataGridTemplateColumn Header="" Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="&#10005;"
                                                         Style="{StaticResource IconBtn}"
                                                         Background="#FF5370"
                                                         Tag="{Binding}"
                                                         Click="DeleteSession_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="SessionTimeError"
                                        Foreground="#FF5370" FontSize="10"
                                        Margin="0,6,0,0" Visibility="Collapsed"
                                        Text="One or more session times are invalid"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
