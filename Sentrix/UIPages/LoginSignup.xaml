<Window x:Class="Sentrix.UIPages.LoginSignup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
        mc:Ignorable="d"
        Title="Welcome" Height="580" Width="450"
        MinHeight="500" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">   
    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                             CornerRadius="5"
                             Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Text Button Style -->
        <Style x:Key="TextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3498DB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2980B9"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Root ScrollViewer ensures nothing is ever clipped on small windows -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <!-- LOGIN FORM -->
            <Border x:Name="LoginForm"
                 Background="White"
                 CornerRadius="10"
                 Margin="30,30,30,30"
                 Padding="35,25,35,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Welcome Back"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="#2C3E50"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,6"/>

                    <TextBlock Text="Sign in to continue"
                            FontSize="13"
                            Foreground="#7F8C8D"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,25"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <TextBox x:Name="LoginEmail"
                          Style="{StaticResource ModernTextBox}"
                          Height="40"
                          Margin="0,0,0,15"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <PasswordBox x:Name="LoginPassword"
                              Style="{StaticResource ModernPasswordBox}"
                              Height="40"
                              Margin="0,0,0,8"/>
                    

                    <!-- Forgot Password -->
                    <TextBlock HorizontalAlignment="Right" Margin="0,0,0,20">
                     <Hyperlink Foreground="#3498DB" TextDecorations="None">
                         <Run Text="Forgot Password?"/>
                     </Hyperlink>
                    </TextBlock>
                    <CheckBox x:Name="RememberMeCheckBox"
          Content="Remember me"
          Margin="0,0,0,10"
          FontSize="13"
          Foreground="#2C3E50"/>

                    <!-- Sign In Button -->
                    <Button Content="Sign In"
                         Style="{StaticResource ModernButton}"
                         Click="LoginButton_Click"
                         Height="43"
                         Margin="0,0,0,15"/>

                    <!-- Switch to Sign Up -->
                    <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? "
                                FontSize="13"
                                Foreground="#7F8C8D"
                                VerticalAlignment="Center"/>
                        <Button Content="Sign Up"
                             Style="{StaticResource TextButton}"
                             Click="ShowSignUp_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SIGN UP FORM -->
            <Border x:Name="SignUpForm"
                 Background="White"
                 CornerRadius="10"
                 Margin="30,30,30,30"
                 Padding="35,20,35,20"
                 Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Create Account"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="#2C3E50"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,6"/>

                    <TextBlock Text="Join us today"
                            FontSize="13"
                            Foreground="#7F8C8D"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20"/>

                    <!-- Full Name -->
                    <TextBlock Text="Full Name"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <TextBox x:Name="SignUpName"
                          Style="{StaticResource ModernTextBox}"
                          Height="40"
                          Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <TextBox x:Name="SignUpEmail"
                          Style="{StaticResource ModernTextBox}"
                          Height="40"
                          Margin="0,0,0,12"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <PasswordBox x:Name="SignUpPassword"
                              Style="{StaticResource ModernPasswordBox}"
                              Height="40"
                              Margin="0,0,0,12"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="Confirm Password"
                            FontSize="13"
                            Foreground="#2C3E50"
                            Margin="0,0,0,4"/>
                    <PasswordBox x:Name="SignUpConfirmPassword"
                              Style="{StaticResource ModernPasswordBox}"
                              Height="40"
                              Margin="0,0,0,18"/>

                    <!-- Create Account Button -->
                    <Button Content="Create Account"
                         Style="{StaticResource ModernButton}"
                         Click="SignUpButton_Click"
                         Height="43"
                         Margin="0,0,0,15"/>

                    <!-- Switch to Login -->
                    <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Center">
                        <TextBlock Text="Already have an account? "
                                FontSize="13"
                                Foreground="#7F8C8D"
                                VerticalAlignment="Center"/>
                        <Button Content="Sign In"
                             Style="{StaticResource TextButton}"
                             Click="ShowLogin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
