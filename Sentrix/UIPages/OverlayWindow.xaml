<Window x:Class="Sentrix.UIPages.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Manual">
    <Grid>
        <!-- Invisible blocker surface -->
        <Border x:Name="BlockerSurface"
             Background="Transparent"
             />

        <!-- Alert box (hidden by default) -->
        <Border x:Name="AlertBox"
             Background="#DD222222"
             CornerRadius="6"
             Padding="10"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"
             Visibility="Hidden"
             Opacity="0.9">
            <TextBlock x:Name="AlertText"
                    Foreground="White"
                    FontSize="14"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    Text="Alert placeholder"/>
        </Border>
    </Grid>
</Window>
