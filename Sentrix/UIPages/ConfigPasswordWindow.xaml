<Window x:Class="Sentrix.UIPages.ConfigPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix.UIPages"
        mc:Ignorable="d"
        Title="Administrator Unlock"
Width="340"
Height="205"
WindowStartupLocation="CenterScreen"
ResizeMode="NoResize"
WindowStyle="ToolWindow"
Topmost="True"
Background="#1E1E1E"
Foreground="#D4D4D4">
    <Border CornerRadius="6"
    BorderThickness="1"
    BorderBrush="#3C3C3C"
    Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Password -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Password"
                   FontSize="12"
                   Foreground="#9CA3AF"/>
                <PasswordBox x:Name="PwdBox"
                     Height="30"
                     Margin="0,6,0,0"
                     Padding="6"
                     Background="#252526"
                     Foreground="#FFFFFF"
                     BorderBrush="#3C3C3C"/>
            </StackPanel>

            <!-- Button -->
            <Button Grid.Row="4"
            Content="Unlock"
            Height="32"
            Width="110"
            HorizontalAlignment="Right"
            Background="#007ACC"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            Click="Unlock_Click"/>
        </Grid>
    </Border>
</Window>
