<Window x:Class="Sentrix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sentrix"
        
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown"
        Focusable="True"
        Title="Sentirx" Height="450" Width="460">
    <Border CornerRadius="12"
         Padding="10"
         Background="#1E1E1E"
         BorderBrush="#2A2A2A"
         BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <!--<ColumnDefinition Width="Auto"/>-->
                </Grid.ColumnDefinitions>

                <Button x:Name="BlockClicksBtn"
                     Grid.Column="0"
                     Width="44"
                     Height="44"
                     Click="BlockClicks_Click"
                     Background="#2D2D2D"
                     BorderThickness="0"
                     Cursor="Hand">
                    <Border CornerRadius="8" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock x:Name="BlockIcon"
                                Text="🛡️"
                                FontSize="22"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <TextBlock x:Name="StatusText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Foreground="#B0B0B0"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Waiting for MetaTrader..."
                        TextWrapping="Wrap" 
                        Margin="5,0"/>

                <Button x:Name="CloseTraderBtn"
                     Grid.Column="3"
                     Width="90"
                     Height="34"
                     Click="CloseTrader_Click"
                     Content="Close MT"
                     Background="#3A3A3A"
                     Foreground="White"
                     BorderThickness="0"
                     Cursor="Hand"
                     Margin="4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                 CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="EventLogBtn"
                     Grid.Column="4"
                     Width="40"
                     Height="34"
                     Click="EventLogBtn_Click"
                     Background="#2D2D2D"
                     BorderThickness="0"
                     Cursor="Hand"
                     Margin="4,0">
                    <Border CornerRadius="8" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock Text="📄"
                                FontSize="18"
                                Foreground="White"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <Button x:Name="SettingsBtn"
                     Grid.Column="5"
                     Width="40"
                     Height="34"
                     Click="SettingsBtn_Click"
                     Background="#2D2D2D"
                     BorderThickness="0"
                     Cursor="Hand"
                     Margin="4,0">
                    <Border CornerRadius="8" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock Text="⚙"
                                FontSize="18"
                                Foreground="White"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <Button x:Name="MinimizeBtn"
                     Grid.Column="6"
                     Width="40"
                     Height="34"
                     Click="MinimizeBtn_Click"
                     Background="#2D2D2D"
                     BorderThickness="0"
                     Cursor="Hand"
                     Margin="4,0">
                    <Border CornerRadius="8" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock Text="➖"
                                FontSize="18"
                                Foreground="White"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                    </Border>
                </Button>
                <Button x:Name="AdminPanelBtn"
                        Visibility="Collapsed"
                 Grid.Column="7"
                 Width="40"
                 Height="34"
                 Click="AdminPanelBtn_Click"
                 Background="#2D2D2D"
                 BorderThickness="0"
                 Cursor="Hand"
                 Margin="4,0">
                    <Border CornerRadius="8" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock Text="👨‍💼"
                        FontSize="18"
                        Foreground="White"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>
                    </Border>
                </Button>

                <!--<Button Grid.Column="3"
                     x:Name="ManualExtractBtn"
                     Visibility="Collapsed"
                     Width="70"
                     Height="34"
                     Click="ManualExtract_Click"
                     Content="Extract"
                     Background="#2D6DA5"
                     Foreground="White"/>-->
            </Grid>
        </Grid>
    </Border>
</Window>
